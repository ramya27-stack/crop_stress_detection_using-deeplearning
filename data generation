# ════════════════════════════════════════════════════════════
# CELL 3 — DATA GENERATORS
# Title   : Data Loading & Augmentation
# Process : Load images from folders. Apply augmentation
#           (rotation, flip, shift) to artificially increase
#           training variety and reduce overfitting.
#           Algorithm: ImageDataGenerator (Keras)
# ════════════════════════════════════════════════════════════

train_datagen = ImageDataGenerator(
    rescale            = 1./255,     # normalise pixel values 0-1
    rotation_range     = 15,
    width_shift_range  = 0.1,
    height_shift_range = 0.1,
    horizontal_flip    = True,
    validation_split   = 0.2,       # 80% train, 20% validation
)
test_datagen = ImageDataGenerator(rescale=1./255)

train_gen = train_datagen.flow_from_directory(
    TRAIN_DIR,
    target_size = CONFIG['img_size'],
    batch_size  = CONFIG['batch_size'],
    class_mode  = 'categorical',
    subset      = 'training',
    shuffle     = True,
    seed        = CONFIG['seed'],
)
val_gen = train_datagen.flow_from_directory(
    TRAIN_DIR,
    target_size = CONFIG['img_size'],
    batch_size  = CONFIG['batch_size'],
    class_mode  = 'categorical',
    subset      = 'validation',
    shuffle     = False,
    seed        = CONFIG['seed'],
)
test_gen = test_datagen.flow_from_directory(
    TEST_DIR,
    target_size = CONFIG['img_size'],
    batch_size  = CONFIG['batch_size'],
    class_mode  = 'categorical',
    shuffle     = False,
)

num_classes  = len(train_gen.class_indices)
idx_to_class = {v: k for k, v in train_gen.class_indices.items()}
class_names  = [idx_to_class[i] for i in range(num_classes)]

# Save class index map for later reloading
with open(f"{CONFIG['results_dir']}/class_indices.json", 'w') as f:
    json.dump(train_gen.class_indices, f, indent=2)

# Fast mode: limit steps per epoch (speeds up CPU training)
if CONFIG['fast_mode']:
    TRAIN_STEPS = max(20, math.ceil(train_gen.samples * 0.25 / CONFIG['batch_size']))
    VAL_STEPS   = max(10, math.ceil(val_gen.samples   * 0.25 / CONFIG['batch_size']))
    print('  FAST MODE ON — 25% data per epoch')
else:
    TRAIN_STEPS = None
    VAL_STEPS   = None
    print('  FAST MODE OFF — full dataset')

# Check class alignment between train and test
train_classes   = set(train_gen.class_indices.keys())
test_classes    = set(test_gen.class_indices.keys())
missing_in_test = train_classes - test_classes
if missing_in_test:
    print(f'\n  WARNING: Classes in train but MISSING from test: {missing_in_test}')
    print(f'  Fix: Create those folders inside {TEST_DIR}/ with at least 1 image each.')
else:
    print('  Classes match between train and test — OK')

print(f'\nCELL 3 done — data generators OK')
print(f'  train_gen  : {train_gen.samples:,} images')
print(f'  val_gen    : {val_gen.samples:,} images')
print(f'  test_gen   : {test_gen.samples:,} images')
print(f'  num_classes: {num_classes}')
