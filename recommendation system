def get_recommendation(class_name: str) -> dict:
    lower = class_name.lower().replace(' ', '_')
    for key, rec in KNOWLEDGE_BASE.items():
        if key in lower or lower in key:
            return rec
    return {**GENERIC_ADVICE, 'full_name': class_name.replace('_', ' ').title()}


def format_recommendation(class_name: str, confidence: float) -> str:
    rec = get_recommendation(class_name)
    sev_emoji = {'None': 'OK', 'Medium': 'WARN', 'High': 'HIGH',
                 'Very High': 'URGENT', 'Medium-High': 'MEDIUM-HIGH'}.get(rec['severity'], '?')
    lines = [
        '=' * 60,
        f"  DIAGNOSIS  : {rec['full_name']}",
        f"  CONFIDENCE : {confidence*100:.1f}%",
        f"  TYPE       : {rec['type']}",
        f"  SEVERITY   : [{sev_emoji}] {rec['severity']}",
        '=' * 60,
        f"  CAUSE      : {rec['cause']}",
        f"  SYMPTOMS   : {rec['symptoms']}",
        '',
        '  TREATMENT (Organic):',
    ]
    for t in rec['treatment']['organic']:
        lines.append(f'    * {t}')
    lines += ['', '  TREATMENT (Chemical):']
    for t in rec['treatment']['chemical']:
        lines.append(f'    * {t}')
    lines += ['', '  PREVENTION:']
    for p in rec['prevention']:
        lines.append(f'    * {p}')
    lines += [
        '',
        f"  IRRIGATION : {rec['irrigation']}",
        f"  FERTILIZER : {rec['fertilizer']}",
        '=' * 60,
    ]
    return '\n'.join(lines)


