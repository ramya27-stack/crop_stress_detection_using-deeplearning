
# ════════════════════════════════════════════════════════════
# CELL 8 — MODEL EVALUATION
# Title   : Test Set Evaluation & Confusion Matrix
# Process : Run the trained model on unseen test images.
#           Generate confusion matrix to see which classes
#           are confused with each other.
#           Metrics: Accuracy, Top-3 Accuracy, Precision,
#                    Recall, F1-Score per class.
# ════════════════════════════════════════════════════════════

print('CELL 8 — Evaluating on test set...')
test_gen.reset()

y_pred_probs = model.predict(test_gen, verbose=1)
y_pred       = np.argmax(y_pred_probs, axis=1)
y_true       = test_gen.classes

# Align lengths in case of batch rounding
min_len  = min(len(y_true), len(y_pred))
y_true   = y_true[:min_len]
y_pred   = y_pred[:min_len]

print('\n  Classification Report:')
report = classification_report(y_true, y_pred, target_names=class_names)
print(report)

with open(f"{CONFIG['results_dir']}/classification_report.txt", 'w') as f:
    f.write(report)

test_loss, test_acc, test_top3 = model.evaluate(test_gen, verbose=0)
print(f'  Test Accuracy  : {test_acc*100:.2f}%')
print(f'  Top-3 Accuracy : {test_top3*100:.2f}%')
print(f'  Test Loss      : {test_loss:.4f}')

# Confusion matrix
cm      = confusion_matrix(y_true, y_pred)
cm_norm = cm.astype('float') / cm.sum(axis=1, keepdims=True)

fig, ax = plt.subplots(figsize=(max(8, num_classes), max(6, num_classes - 2)),
                        facecolor='#0a0f0a')
ax.set_facecolor('#111811')
sns.heatmap(cm_norm, annot=True, fmt='.2f', cmap='Greens',
            xticklabels=class_names, yticklabels=class_names,
            ax=ax, linewidths=0.3, linecolor='#1e2e1e', cbar_kws={'shrink': 0.8})
ax.set_title('Confusion Matrix (Normalised)', color='white', fontsize=13, fontweight='bold')
ax.set_xlabel('Predicted Label', color='#5a7a5a', fontsize=10)
ax.set_ylabel('True Label',      color='#5a7a5a', fontsize=10)
ax.tick_params(colors='white', labelsize=8)
plt.xticks(rotation=45, ha='right')
plt.tight_layout()
plt.savefig(f"{CONFIG['results_dir']}/confusion_matrix.png",
            dpi=150, bbox_inches='tight', facecolor='#0a0f0a')
plt.show()
print('CELL 8 done — evaluation complete')
